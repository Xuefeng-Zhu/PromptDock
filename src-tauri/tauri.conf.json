{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "PromptDock",
  "version": "0.1.0",
  "identifier": "com.promptdock.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "PromptDock",
        "width": 1024,
        "height": 768,
        "resizable": true,
        "fullscreen": false
      },
      {
        "label": "quicklauncher",
        "title": "Quick Launcher",
        "url": "/quicklauncher",
        "width": 600,
        "height": 400,
        "resizable": false,
        "decorations": false,
        "alwaysOnTop": true,
        "visible": false,
        "center": true
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true
    },
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "global-shortcut": { "enabled": true },
    "clipboard-manager": { "enabled": true },
    "store": { "enabled": true }
  }
}
